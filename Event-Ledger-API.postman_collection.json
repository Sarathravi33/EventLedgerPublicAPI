{
  "info": {
    "_postman_id": "6f2a8d3e-6b1a-4a2f-9d4e-2e7a1c9f0a11",
    "name": "Event Ledger API",
    "description": "Collection for both services in the Event Ledger system.\n\nPrerequisites: both services must be running — either `docker compose up --build` from the repo root, or `mvn -pl account-service spring-boot:run` and `mvn -pl event-gateway spring-boot:run` in two terminals.\n\nDefault base URLs (override via the collection variables if running elsewhere):\n- Event Gateway (public): http://localhost:8082\n- Account Service (internal): http://localhost:8081\n\nEach request that asserts a status code carries a Postman test script, so this collection can be run end-to-end (Collection Runner / Newman) as a smoke test, not just used for manual demo clicks. Requests that submit a fixed eventId are deliberately idempotent-friendly: re-running the collection is expected to show 200 (duplicate replay) on the second pass instead of 201 — that IS the idempotency behavior being demonstrated, not a failure.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gatewayBaseUrl", "value": "http://localhost:8082", "type": "string" },
    { "key": "accountServiceBaseUrl", "value": "http://localhost:8081", "type": "string" }
  ],
  "item": [
    {
      "name": "01 - Event Gateway (public)",
      "item": [
        {
          "name": "Happy Path",
          "item": [
            {
              "name": "Submit New Event (CREDIT)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 201 (new) or 200 (duplicate replay on a rerun)', function () {",
                      "    pm.expect([200, 201]).to.include(pm.response.code);",
                      "});",
                      "pm.test('Response body has the submitted eventId', function () {",
                      "    pm.expect(pm.response.json().eventId).to.eql('evt-postman-credit-001');",
                      "});",
                      "pm.test('Event status is APPLIED', function () {",
                      "    pm.expect(pm.response.json().status).to.eql('APPLIED');",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [ { "key": "Content-Type", "value": "application/json" } ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"eventId\": \"evt-postman-credit-001\", \"accountId\": \"acct-postman-1\", \"type\": \"CREDIT\", \"amount\": 150.00, \"currency\": \"USD\", \"eventTimestamp\": \"2026-05-15T14:02:11Z\", \"metadata\": {\"source\": \"postman\", \"batchId\": \"B-9042\"}}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{gatewayBaseUrl}}/events",
                  "host": [ "{{gatewayBaseUrl}}" ],
                  "path": [ "events" ]
                },
                "description": "Submits a new CREDIT event. Run twice to see idempotent replay: 201 then 200 with the exact same stored record."
              },
              "response": []
            },
            {
              "name": "Submit New Event (DEBIT)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 201 or 200', function () {",
                      "    pm.expect([200, 201]).to.include(pm.response.code);",
                      "});",
                      "pm.test('Event type is DEBIT', function () {",
                      "    pm.expect(pm.response.json().type).to.eql('DEBIT');",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [ { "key": "Content-Type", "value": "application/json" } ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"eventId\": \"evt-postman-debit-001\", \"accountId\": \"acct-postman-1\", \"type\": \"DEBIT\", \"amount\": 40.00, \"currency\": \"USD\", \"eventTimestamp\": \"2026-05-15T15:00:00Z\"}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{gatewayBaseUrl}}/events",
                  "host": [ "{{gatewayBaseUrl}}" ],
                  "path": [ "events" ]
                },
                "description": "Submits a DEBIT event for the same account, without metadata (metadata is optional)."
              },
              "response": []
            },
            {
              "name": "Submit Out-of-Order Event (earlier timestamp, sent last)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 201 or 200', function () {",
                      "    pm.expect([200, 201]).to.include(pm.response.code);",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [ { "key": "Content-Type", "value": "application/json" } ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"eventId\": \"evt-postman-early-001\", \"accountId\": \"acct-postman-1\", \"type\": \"CREDIT\", \"amount\": 10.00, \"currency\": \"USD\", \"eventTimestamp\": \"2026-05-15T13:00:00Z\"}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{gatewayBaseUrl}}/events",
                  "host": [ "{{gatewayBaseUrl}}" ],
                  "path": [ "events" ]
                },
                "description": "eventTimestamp (13:00) is earlier than both events above, but this is physically the third request sent. Run 'List Events For Account' afterward to see it correctly sorted first — demonstrating out-of-order tolerance."
              },
              "response": []
            },
            {
              "name": "Get Event By Id",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                      "pm.test('eventId matches', function () { pm.expect(pm.response.json().eventId).to.eql('evt-postman-credit-001'); });"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{gatewayBaseUrl}}/events/evt-postman-credit-001",
                  "host": [ "{{gatewayBaseUrl}}" ],
                  "path": [ "events", "evt-postman-credit-001" ]
                },
                "description": "Pure local read — works even if the Account Service is down."
              },
              "response": []
            },
            {
              "name": "List Events For Account (chronological order)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                      "pm.test('Response is an array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
                      "pm.test('Events are sorted by eventTimestamp ascending', function () {",
                      "    var events = pm.response.json();",
                      "    for (var i = 1; i < events.length; i++) {",
                      "        pm.expect(new Date(events[i].eventTimestamp).getTime())",
                      "          .to.be.at.least(new Date(events[i - 1].eventTimestamp).getTime());",
                      "    }",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{gatewayBaseUrl}}/events?account=acct-postman-1",
                  "host": [ "{{gatewayBaseUrl}}" ],
                  "path": [ "events" ],
                  "query": [ { "key": "account", "value": "acct-postman-1" } ]
                },
                "description": "Ordered by eventTimestamp, not submission order — run this after the three 'Submit' requests above to see the out-of-order event correctly placed first."
              },
              "response": []
            },
            {
              "name": "Get Balance (Gateway proxy)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                      "pm.test('Response has accountId and balance', function () {",
                      "    var body = pm.response.json();",
                      "    pm.expect(body.accountId).to.eql('acct-postman-1');",
                      "    pm.expect(body.balance).to.be.a('number');",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{gatewayBaseUrl}}/accounts/acct-postman-1/balance",
                  "host": [ "{{gatewayBaseUrl}}" ],
                  "path": [ "accounts", "acct-postman-1", "balance" ]
                },
                "description": "Proxies to the Account Service. Returns 503 with a clear message if the Account Service is unreachable — try stopping it to see this."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Idempotency",
          "item": [
            {
              "name": "Submit Duplicate Event (expect 200, not a new row)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200 (idempotent replay)', function () { pm.response.to.have.status(200); });",
                      "pm.test('Returns the original stored eventId', function () {",
                      "    pm.expect(pm.response.json().eventId).to.eql('evt-postman-credit-001');",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [ { "key": "Content-Type", "value": "application/json" } ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"eventId\": \"evt-postman-credit-001\", \"accountId\": \"acct-postman-1\", \"type\": \"CREDIT\", \"amount\": 150.00, \"currency\": \"USD\", \"eventTimestamp\": \"2026-05-15T14:02:11Z\"}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{gatewayBaseUrl}}/events",
                  "host": [ "{{gatewayBaseUrl}}" ],
                  "path": [ "events" ]
                },
                "description": "Run 'Submit New Event (CREDIT)' first, then this — identical eventId returns the original record and does not double-apply the balance."
              },
              "response": []
            }
          ]
        },
