    {
      "name": "02 - Account Service (internal)",
      "item": [
        {
          "name": "Happy Path",
          "item": [
            {
              "name": "Apply Transaction (CREDIT)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 201 (new) or 200 (duplicate replay on a rerun)', function () {",
                      "    pm.expect([200, 201]).to.include(pm.response.code);",
                      "});",
                      "pm.test('Response has accountId and balance', function () {",
                      "    var body = pm.response.json();",
                      "    pm.expect(body.accountId).to.eql('acct-postman-direct-1');",
                      "    pm.expect(body.balance).to.be.a('number');",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [ { "key": "Content-Type", "value": "application/json" } ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"eventId\": \"evt-direct-credit-001\", \"type\": \"CREDIT\", \"amount\": 200.00, \"eventTimestamp\": \"2026-05-15T14:02:11Z\"}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{accountServiceBaseUrl}}/accounts/acct-postman-direct-1/transactions",
                  "host": [ "{{accountServiceBaseUrl}}" ],
                  "path": [ "accounts", "acct-postman-direct-1", "transactions" ]
                },
                "description": "Calling the Account Service directly (bypassing the Gateway) — the account is created automatically since it's the first transaction. Note: no 'currency' field here; that's Gateway-only (see FIXES.md/IMPLEMENTATION_PLAN.md §6.2 for why)."
              },
              "response": []
            },
            {
              "name": "Apply Transaction (DEBIT)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 201 or 200', function () {",
                      "    pm.expect([200, 201]).to.include(pm.response.code);",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [ { "key": "Content-Type", "value": "application/json" } ],
